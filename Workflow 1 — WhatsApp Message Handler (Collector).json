    {
      "parameters": {
        "jsCode": "// Validate & Extract Payload (supports multiple attachments + quoted attachments)\nconst body = $input.first().json.body || $input.first().json;\n\n// Validate account_id\nconst expectedAccountId = \"kACkIGbpSACHY7MvXS_afw\";\nif (body.account_id !== expectedAccountId) {\n  return []; // Stop silently — wrong account\n}\n\n// Ignore own messages\nif (body.is_sender === true) {\n  return []; // Stop silently — own message\n}\n\n// Extract direct attachments (body.attachments)\nconst directAttachments = (body.attachments && body.attachments.length > 0)\n  ? body.attachments.map(a => ({\n      id: a.attachment_id || a.id,\n      type: a.attachment_type || a.type,\n      source: 'direct'\n    }))\n  : [];\n\n// Extract quoted attachments (body.quoted.attachments) ← THIS WAS MISSING\nconst quotedAttachments = (body.quoted?.attachments && body.quoted.attachments.length > 0)\n  ? body.quoted.attachments.map(a => ({\n      id: a.attachment_id || a.id,\n      type: a.attachment_type || a.type,\n      source: 'quoted'\n    }))\n  : [];\n\n// Merge both arrays\nconst attachments = [...directAttachments, ...quotedAttachments];\n\nreturn [{\n  json: {\n    chat_id: body.chat_id || '',\n    message_text: body.message || '',\n    sender_phone: body.attendees?.[0]?.attendee_specifics?.phone_number || '',\n    has_attachment: attachments.length > 0,\n    attachments: attachments,\n    unipile_msg_id: body.message_id || '',\n    raw_event: body.event || ''\n  }\n}];"
      },
