        "jsCode": "// Upload attachments to Supabase Storage\n// Uses Node.js built-in https module (fetch() is not available in n8n Cloud sandbox)\nconst https = require('https');\nconst originalData = $node['Validate & Extract Payload'].json;\nconst msgId = originalData.unipile_msg_id;\n\nconst SUPABASE_SERVICE_KEY = $env.SUPABASE_SERVICE_KEY;\nconst UNIPILE_API_KEY = $env.UNIPILE_API_KEY;\nconst SUPABASE_URL = 'https://rifktjxmadzfrdclxpfz.supabase.co';\nconst BUCKET = 'chat-attachments';\n\n// Support both old format (attachment_id) and new format (attachments array)\nlet allAttachments = originalData.attachments || [];\nif (allAttachments.length === 0 && originalData.attachment_id) {\n  allAttachments = [{ id: originalData.attachment_id, type: originalData.attachment_type || 'img' }];\n}\n\nconst uploadedUrls = [];\nconst debugLog = [];\ndebugLog.push(`Found ${allAttachments.length} attachment(s)`);\n\n// Helper: make HTTPS request and return buffer\nfunction httpsRequest(url, options, body) {\n  return new Promise((resolve, reject) => {\n    const req = https.request(url, options, (res) => {\n      const chunks = [];\n      res.on('data', chunk => chunks.push(chunk));\n      res.on('end', () => {\n        resolve({\n          statusCode: res.statusCode,\n          headers: res.headers,\n          body: Buffer.concat(chunks)\n        });\n      });\n    });\n    req.on('error', reject);\n    if (body) req.write(body);\n    req.end();\n  });\n}\n\n// Process each attachment\nfor (let i = 0; i < allAttachments.length; i++) {\n  const att = allAttachments[i];\n  try {\n    // 1. Fetch binary from Unipile\n    debugLog.push(`Fetching attachment ${i}: ${att.id}`);\n    const fetchRes = await httpsRequest(\n      `https://api20.unipile.com:15040/api/v1/messages/${msgId}/attachments/${att.id}`,\n      {\n        method: 'GET',\n        headers: { 'X-API-KEY': UNIPILE_API_KEY, 'accept': '*/*' }\n      }\n    );\n\n    debugLog.push(`Fetch status: ${fetchRes.statusCode}, size: ${fetchRes.body.length}`);\n\n    if (fetchRes.statusCode !== 200) {\n      debugLog.push(`Fetch failed: ${fetchRes.statusCode}`);\n      continue;\n    }\n\n    // 2. Determine file extension and content type\n    const ext = att.type === 'img' ? 'jpg' : (att.type === 'video' ? 'mp4' : 'bin');\n    const contentType = att.type === 'img' ? 'image/jpeg' : (att.type === 'video' ? 'video/mp4' : 'application/octet-stream');\n    const fileName = `${originalData.chat_id}/${Date.now()}_${i}.${ext}`;\n\n    // 3. Upload to Supabase Storage\n    debugLog.push(`Uploading to Supabase: ${fileName}`);\n    const uploadRes = await httpsRequest(\n      `${SUPABASE_URL}/storage/v1/object/${BUCKET}/${fileName}`,\n      {\n        method: 'POST',\n        headers: {\n          'Authorization': `Bearer ${SUPABASE_SERVICE_KEY}`,\n          'Content-Type': contentType,\n          'x-upsert': 'true',\n          'Content-Length': fetchRes.body.length\n        }\n      },\n      fetchRes.body\n    );\n\n    debugLog.push(`Upload status: ${uploadRes.statusCode}`);\n\n    if (uploadRes.statusCode >= 200 && uploadRes.statusCode < 300) {\n      const publicUrl = `${SUPABASE_URL}/storage/v1/object/public/${BUCKET}/${fileName}`;\n      uploadedUrls.push(publicUrl);\n      debugLog.push(`Success: ${publicUrl}`);\n    } else {\n      debugLog.push(`Upload failed: ${uploadRes.statusCode} ${uploadRes.body.toString()}`);\n    }\n  } catch (e) {\n    debugLog.push(`Error for ${att.id}: ${e.message}`);\n  }\n}\n\n// Build output compatible with downstream Save Message nodes\nlet attachmentUrl = null;\nif (uploadedUrls.length === 1) {\n  attachmentUrl = uploadedUrls[0];\n} else if (uploadedUrls.length > 1) {\n  attachmentUrl = JSON.stringify(uploadedUrls);\n}\n\nreturn [{\n  json: {\n    chat_id: originalData.chat_id,\n    message_text: originalData.message_text,\n    sender_phone: originalData.sender_phone,\n    has_attachment: originalData.has_attachment,\n    unipile_msg_id: originalData.unipile_msg_id,\n    raw_event: originalData.raw_event,\n    attachment_url: attachmentUrl,\n    attachment_urls: uploadedUrls,\n    _debug: debugLog\n  }\n}];"
      },
