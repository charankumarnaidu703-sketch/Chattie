    {
      "parameters": {
        "jsCode": "// Validate & Extract Payload (supports multiple attachments)\nconst body = $input.first().json.body || $input.first().json;\n\n// Validate account_id\nconst expectedAccountId = \"kACkIGbpSACHY7MvXS_afw\";\nif (body.account_id !== expectedAccountId) {\n  return []; // Stop silently — wrong account\n}\n\n// Ignore own messages (Unipile uses is_sender, not from_me)\nif (body.is_sender === true) {\n  return []; // Stop silently — own message\n}\n\n// Extract ALL attachments\nconst allAttachments = (body.attachments && body.attachments.length > 0)\n  ? body.attachments.map(a => ({ id: a.attachment_id, type: a.attachment_type }))\n  : [];\n\n// First attachment fields for HTTP Request node URL template\nconst firstAttachment = allAttachments.length > 0 ? allAttachments[0] : null;\n\nreturn [{\n  json: {\n    chat_id: body.chat_id || '',\n    message_text: body.message || '',\n    sender_phone: body.attendees?.[0]?.attendee_specifics?.phone_number || '',\n    has_attachment: allAttachments.length > 0,\n    attachment_id: firstAttachment ? firstAttachment.id : null,\n    attachment_type: firstAttachment ? firstAttachment.type : null,\n    attachments: allAttachments,\n    unipile_msg_id: body.message_id || '',\n    raw_event: body.event || ''\n  }\n}];"
      },
