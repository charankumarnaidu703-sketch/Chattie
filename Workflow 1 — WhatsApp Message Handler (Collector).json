    {
      "parameters": {
        "jsCode": "// Merge conversation data from either existing or newly created path\nconst items = $input.all();\nconst data = items[0].json;\n\n// Handle both array response (Supabase) and direct object\nconst conv = Array.isArray(data) ? data[0] : (data.body ? (Array.isArray(data.body) ? data.body[0] : data.body) : data);\n\nreturn [{\n  json: {\n    conversation_id: conv.id,\n    contact_id: conv.contact_id,\n    whatsapp_chat_id: conv.whatsapp_chat_id || $node['Validate & Extract Payload1'].json.chat_id,\n    bot_paused: conv.bot_paused || false,\n    qualification_complete: conv.qualification_complete || false,\n    qualification_step: conv.qualification_step || 1,\n    collected_address: conv.collected_address || null,\n    collected_wishes: conv.collected_wishes || null,\n    collected_dimensions: conv.collected_dimensions || null,\n    collected_email: conv.collected_email || null,\n    collected_photos: conv.collected_photos || [],\n    status: conv.status || 'active',\n    // Carry forward message data\n    chat_id: $node['Validate & Extract Payload1'].json.chat_id,\n    message_text: $node['Validate & Extract Payload1'].json.message_text,\n    sender_phone: $node['Validate & Extract Payload1'].json.sender_phone,\n    has_attachment: $node['Validate & Extract Payload1'].json.has_attachment,\n    attachment_url: $node['Validate & Extract Payload1'].json.attachment_url || null,\n    unipile_msg_id: $node['Validate & Extract Payload1'].json.unipile_msg_id\n  }\n}];"
      },
