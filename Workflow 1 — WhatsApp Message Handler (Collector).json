      "parameters": {
        "jsCode": "// Global Error Handler\n// Logs error to Supabase system_events table\nconst error = $input.first().json;\nconst errorMessage = error.message || error.error || 'Unknown error';\nconst errorNode = error.node || error.nodeName || 'Unknown node';\n\n// We'll make an HTTP call to Supabase to log this\nconst supabaseUrl = $env.SUPABASE_URL;\n\nreturn [{\n  json: {\n    type: 'error',\n    description: String(errorMessage).substring(0, 500),\n    metadata: {\n      workflow: 'whatsapp-handler',\n      node: errorNode,\n      timestamp: new Date().toISOString()\n    }\n  }\n}];"
