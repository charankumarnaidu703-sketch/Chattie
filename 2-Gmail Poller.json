    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4",
          "mode": "list",
          "cachedResultName": "GPT-4"
        },
        "messages": {
          "values": [
            {
              "content": "=You classify emails for a professional landscaping and gardening company.\\n\\nCUSTOMER — A real person asking about garden services, lawn care, landscaping, requesting a quote, asking if we do their area, or any genuine customer inquiry.\\n\\nSUPPLIER — A business or individual selling products or services TO the company. Trade suppliers, tool vendors, B2B offers.\\n\\n(SPAM) — Cold sales outreach, marketing newsletters, lead-selling services (\\\"we have customers for you\\\"), phishing, mass mailings, discount offers.\\n\\nINTERNAL — Automated notifications from Google, Stripe, banks, software tools, booking confirmations, receipts.\\n\\nOTHER — Anything that genuinely doesn't fit the above.\\n\\nIMPORTANT:\\n- \\\"We can get you more customers\\\" = SPAM not CUSTOMER\\n- \\\"I want a new garden\\\" = CUSTOMER\\n- Marketing agency offering services = SPAM\\n\\nRespond with JSON only:\\n{\\n  \\\"classification\\\": \\\"CUSTOMER\\\",\\n  \\\"confidence\\\": 0.97,\\n  \\\"reasoning\\\": \\\"Person asking for quote on garden renovation\\\"\\n}",
              "role": "system"
            },
            {
              "content": "=Subject: {{ $json.subject }}\\nFrom: {{ $json.senderName }} <{{ $json.senderEmail }}>\\n\\nBody:\\n{{ $json.body }}"
            }
          ]
        },
        "options": {
          "temperature": 0.1
        }
      },
      "id": "5c1472e3-775e-4344-aba9-3b625e1d08df",
      "name": "OpenAI — Classify Email",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        176,
        0
      ],
      "credentials": {
        "openAiApi": {
          "id": "XR9xujmItcOh3eRv",
          "name": "OpenAi account 2"
        }
