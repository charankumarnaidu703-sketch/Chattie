    {
      "parameters": {
        "jsCode": "// Extract full email details from Gmail item\nconst item = $node['Split In Batches'].json;\n\nconst messageId = item.id || '';\nconst threadId = item.threadId || '';\n\n// ✅ Fixed: Capital S for Subject\nconst subject = item.Subject || item.subject || '(no subject)';\n\n// ✅ Fixed: Body fallback since textPlain not in payload\nconst body = item.textPlain || item.textHtml || item.snippet || '';\n\n// ✅ Fixed: Capital F for From\nconst fromHeader = item.From || item.from || '';\nlet senderName = '';\nlet senderEmail = '';\n\nif (fromHeader) {\n  const match = fromHeader.match(/^(.+?)\\s*<(.+?)>$/);\n  if (match) {\n    senderName = match[1].replace(/\"/g, '').trim();\n    senderEmail = match[2].trim();\n  } else {\n    senderEmail = fromHeader.trim();\n    senderName = senderEmail.split('@')[0];\n  }\n}\n\n// ✅ Fixed: labels is array of objects {id, name} not strings\nconst labelsRaw = item.labels || item.labelIds || [];\nconst labels = labelsRaw.map(l => typeof l === 'object' ? l.name || l.id : l);\n\nreturn [{\n  json: {\n    messageId: messageId,\n    threadId: threadId,\n    subject: subject,\n    body: body.substring(0, 3000),\n    senderName: senderName,\n    senderEmail: senderEmail,\n    labels: labels,\n    snippet: item.snippet || ''\n  }\n}];"
      },
      "id": "f0c7aeae-d3eb-4d80-bf85-85b356923fcb",
      "name": "Extract Email Details",
