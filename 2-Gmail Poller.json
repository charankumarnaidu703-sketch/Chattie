        "messages": {
          "values": [
            {
              "content": "=You write draft email responses and also  subject for a landscaping company owner to review and send.\\n\\nWrite a warm, professional response that:\\n1. Opens by thanking them by name for their message\\n2. Addresses their specific question or request with useful information\\n3. Asks for ANY information missing from this list:\\n   - Phone number (ALWAYS ask if not in email — this is the most critical item)\\n   - Dimensions of the area to be worked on (as Length x Width in meters)\\n   - Photos of the current situation\\n   - Full address of the property\\n4. Mentions we are happy to visit for a free quote\\n5. Ends with this exact signature:\\n\\n---\\nMet vriendelijke groet / Kind regards,\\n\\n[Owner Name]\\n[Company Name]\\nTel: [Phone Number]\\nWebsite: [Website URL]\\n\\nRULES:\\n- Never quote a specific price\\n- Never promise a specific date\\n- Language: match the customer (Dutch or English)\\n- Length: 150-250 words\\n- Format: plain HTML paragraphs only, no fancy styling\\n\\nRespond with the email body HTML only — no JSON wrapper, no subject line",
              "role": "system"
            },
            {
              "content": "==Customer name: {{ $node['Parse Classification'].json['senderName'] }}\\nEmail: \n\n\n{{ $node['Parse Classification'].json['senderEmail'] }}\\nSubject: \n{{ $node['Parse Classification'].json['subject']}}\\n\\nMessage:\\n\n{{ $node['Parse Classification'].json['body'] }}\n\n\n"
            }
          ]
        },
        "options": {
          "temperature": 0.4
        }
      },
      "id": "1f80c0be-f17b-4573-a18a-274a9d1b86aa",
      "name": "OpenAI — Generate Draft Response",
