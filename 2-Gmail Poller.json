      "parameters": {
        "jsCode": "// Filter emails that don't have classification labels yet\nconst classificationLabels = ['CUSTOMER', 'SUPPLIER', 'SPAM', 'INTERNAL', 'OTHER'];\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  const email = item.json;\n  \n  // Get label names from labels array (handles both object and string format)\n  const labelNames = (email.labels || []).map(l => \n    typeof l === 'object' ? (l.name || l.id) : l\n  );\n\n  // Check if any classification label already exists\n  const hasClassificationLabel = labelNames.some(label => \n    classificationLabels.some(cl => label.includes(cl))\n  );\n\n  // ✅ Only pass through emails WITHOUT classification labels\n  if (!hasClassificationLabel) {\n    results.push({\n      json: email,\n      pairedItem: { item: item.index ?? results.length }\n    });\n  }\n}\n\nreturn results;\n"
      },
