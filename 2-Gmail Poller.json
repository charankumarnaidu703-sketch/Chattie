    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "claude-sonnet-4-20250514",
          "mode": "list",
          "cachedResultName": "claude-sonnet-4-20250514"
        },
        "messages": {
          "values": [
            {
              "content": "=Subject: {{ $json.subject }}\\nFrom: {{ $json.senderName }} <{{ $json.senderEmail }}>\\n\\nBody:\\n{{ $json.body }}"
            }
          ]
        },
        "simplify": false,
        "options": {
          "system": "You classify emails for a professional landscaping and gardening company.\\n\\nCUSTOMER — A real person asking about garden services, lawn care, landscaping, requesting a quote, asking if we do their area, or any genuine customer inquiry.\\n\\nSUPPLIER — A business or individual selling products or services TO the company. Trade suppliers, tool vendors, B2B offers.\\n\\nSPAM — Cold sales outreach, marketing newsletters, lead-selling services (\\\"we have customers for you\\\"), phishing, mass mailings, discount offers.\\n\\nINTERNAL — Automated notifications from Google, Stripe, banks, software tools, booking confirmations, receipts.\\n\\nOTHER — Anything that genuinely doesn't fit the above.\\n\\nIMPORTANT:\\n- \\\"We can get you more customers\\\" = SPAM not CUSTOMER\\n- \\\"I want a new garden\\\" = CUSTOMER\\n- Marketing agency offering services = SPAM\\n\\nRespond with JSON only:\\n{\\n  \\\"classification\\\": \\\"CUSTOMER\\\",\\n  \\\"confidence\\\": 0.97,\\n  \\\"reasoning\\\": \\\"Person asking for quote on garden renovation\\\"\\n}"
        }
      },
