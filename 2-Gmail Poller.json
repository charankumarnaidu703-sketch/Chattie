    {
      "parameters": {
        "jsCode": "// Extract draft content from OpenAI response\nconst rawContent = $input.first().json.message?.content || $input.first().json.choices?.[0]?.message?.content || $input.first().json.text || '';\nconst emailData = $node['Parse Classification'].json;\n\n// ✅ Extract subject from AI response content\nlet extractedSubject = emailData.subject || '';\nlet draftBody = rawContent;\n\nconst subjectMatch = rawContent.match(/^Subject:\\s*(.+)\\n/);\nif (subjectMatch) {\n  extractedSubject = subjectMatch[1].trim();\n  // Remove subject line from body\n  draftBody = rawContent.replace(/^Subject:\\s*.+\\n\\n?/, '').trim();\n}\n\nreturn [{\n  json: {\n    draftBody: draftBody,\n    subject: extractedSubject,          // ✅ New separate subject field\n    messageId: emailData.messageId,\n    threadId: emailData.threadId,\n    senderName: emailData.senderName,\n    senderEmail: emailData.senderEmail,\n    classification: emailData.classification\n  }\n}];"
      },
