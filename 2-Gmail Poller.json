    {
      "parameters": {
        "jsCode": "// Parse Classification Response\nlet classification = 'OTHER';\nlet confidence = 0;\nlet reasoning = '';\n\ntry {\n  // Handle both object and string content formats\n  let rawContent = $input.first().json.message?.content \n                || $input.first().json.choices?.[0]?.message?.content \n                || $input.first().json.text \n                || '';\n\n  // If already object, use directly. If string, parse it\n  let parsed;\n  if (typeof rawContent === 'object' && rawContent !== null) {\n    parsed = rawContent;\n  } else {\n    parsed = JSON.parse(rawContent);\n  }\n\n  classification = parsed.classification || 'OTHER';\n  confidence = parsed.confidence || 0;\n  reasoning = parsed.reasoning || '';\n\n  // Validate classification is one of allowed types\n  const validTypes = ['CUSTOMER', 'SUPPLIER', 'SPAM', 'INTERNAL', 'OTHER'];\n  if (!validTypes.includes(classification)) {\n    classification = 'OTHER';\n  }\n\n} catch (e) {\n  classification = 'OTHER';\n  confidence = 0;\n  reasoning = 'Failed to parse AI classification: ' + e.message;\n}\n\n// Pass through email data from Extract Email Details node\nconst emailData = $node['Extract Email Details'].json;\n\nreturn [{\n  json: {\n    classification: classification,\n    confidence: confidence,\n    reasoning: reasoning,\n    messageId: emailData.messageId,\n    threadId: emailData.threadId,\n    subject: emailData.subject,\n    body: emailData.body,\n    senderName: emailData.senderName,\n    senderEmail: emailData.senderEmail\n  },\n  pairedItem: { item: 0 } // ✅ Fixes paired item error in Gmail node\n}];"
      },
