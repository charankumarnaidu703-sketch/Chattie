    {
      "parameters": {
        "jsCode": "// Build context for AI draft with company knowledge\\nconst rawKB = $input.first().json;\\nconst emailData = $node['Parse Classification'].json;\\n\\nlet rows = [];\\nif (Array.isArray(rawKB)) rows = rawKB;\\nelse if (Array.isArray(rawKB.body)) rows = rawKB.body;\\nelse if (rawKB.category) rows = [rawKB];\\n\\nconst kb = {};\\nfor (const r of rows) {\\n  if (!kb[r.category]) kb[r.category] = {};\\n  kb[r.category][r.key] = r.value;\\n}\\n\\nlet block = '## COMPANY KNOWLEDGE BASE\\\\n';\\nfor (const cat of ['company_info','services','service_area','pricing']) {\\n  if (kb[cat]) {\\n    block += '\\\\n### ' + cat.replace('_',' ').toUpperCase() + '\\\\n';\\n    for (const [k,v] of Object.entries(kb[cat])) block += '- ' + k + ': ' + v + '\\\\n';\\n  }\\n}\\nif (kb.signature?.default) block += '\\\\n### EMAIL SIGNATURE\\\\n' + kb.signature.default;\\n\\nconst userMsg = `Customer name: ${emailData.senderName}\\\\nEmail: ${emailData.senderEmail}\\\\nSubject: ${emailData.subject}\\\\n\\\\nMessage:\\\\n${emailData.body}`;\\n\\nreturn [{ json: {\\n  knowledgeBlock: block, userMessage: userMsg,\\n  subject: emailData.subject, messageId: emailData.messageId,\\n  threadId: emailData.threadId, senderName: emailData.senderName,\\n  senderEmail: emailData.senderEmail, classification: emailData.classification\\n}}];"
      },
