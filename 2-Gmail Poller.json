      "parameters": {
        "jsCode": "// Extract lastPollTime and compute Gmail search query format\nconst raw = $input.first().json;\nconst rows = Array.isArray(raw) ? raw : (Array.isArray(raw.body) ? raw.body : []);\n\nlet lastPollTime;\nif (rows.length > 0 && rows[0].value) {\n  lastPollTime = rows[0].value;\n} else {\n  // Default: 5 minutes ago if no record exists\n  lastPollTime = new Date(Date.now() - 5 * 60 * 1000).toISOString();\n}\n\n// Format for Gmail search: YYYY/MM/DD\nconst d = new Date(lastPollTime);\nconst gmailAfter = `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}`;\n\n// Also compute epoch seconds for Gmail API after: parameter\nconst epochSeconds = Math.floor(d.getTime() / 1000);\n\nreturn [{\n  json: {\n    lastPollTime: lastPollTime,\n    gmailAfterDate: gmailAfter,\n    epochSeconds: epochSeconds,\n    nowISO: new Date().toISOString()\n  }\n}];"
      },
