    {
      "parameters": {
        "jsCode": "// Parse Classification Response\\nlet classification = 'OTHER';\\nlet confidence = 0;\\nlet reasoning = '';\\n\\ntry {\\n  let rawContent = $input.first().json.content?.[0]?.text\\n                || $input.first().json.message?.content\\n                || $input.first().json.text\\n                || '';\\n\\n  if (typeof rawContent === 'string') {\\n    rawContent = rawContent.replace(/```json\\\\n?|\\\\n?```/g, '').trim();\\n  }\\n\\n  let parsed;\\n  if (typeof rawContent === 'object' && rawContent !== null) {\\n    parsed = rawContent;\\n  } else {\\n    parsed = JSON.parse(rawContent);\\n  }\\n\\n  classification = parsed.classification || 'OTHER';\\n  confidence = parsed.confidence || 0;\\n  reasoning = parsed.reasoning || '';\\n\\n  const validTypes = ['CUSTOMER', 'SUPPLIER', 'SPAM', 'INTERNAL', 'OTHER'];\\n  if (!validTypes.includes(classification)) classification = 'OTHER';\\n\\n} catch (e) {\\n  classification = 'OTHER';\\n  confidence = 0;\\n  reasoning = 'Failed to parse: ' + e.message;\\n}\\n\\nconst emailData = $node['Extract Email Details'].json;\\n\\nreturn [{\\n  json: {\\n    classification, confidence, reasoning,\\n    messageId: emailData.messageId, threadId: emailData.threadId,\\n    subject: emailData.subject, body: emailData.body,\\n    senderName: emailData.senderName, senderEmail: emailData.senderEmail\\n  },\\n  pairedItem: { item: 0 }\\n}];"
      },
