      "parameters": {
        "jsCode": "// Extract draft content from Claude response\\nconst rawContent = $input.first().json.content?.[0]?.text\\n                || $input.first().json.message?.content\\n                || $input.first().json.text || '';\\nconst emailData = $node['Parse Classification'].json;\\n\\nlet extractedSubject = emailData.subject || '';\\nlet draftBody = rawContent;\\n\\nconst subjectMatch = rawContent.match(/^Subject:\\\\s*(.+)\\\\n/);\\nif (subjectMatch) {\\n  extractedSubject = subjectMatch[1].trim();\\n  draftBody = rawContent.replace(/^Subject:\\\\s*.+\\\\n\\\\n?/, '').trim();\\n}\\n\\nreturn [{ json: {\\n  draftBody, subject: extractedSubject,\\n  messageId: emailData.messageId, threadId: emailData.threadId,\\n  senderName: emailData.senderName, senderEmail: emailData.senderEmail,\\n  classification: emailData.classification\\n}}];"
