      "parameters": {
        "jsCode": "// Extract payload\nconst body = $input.first().json.body || $input.first().json;\nreturn [{\n  json: {\n    contactId: body.contactId || '',\n    conversationId: body.conversationId || '',\n    notes: body.notes || '',\n    outcome: body.outcome || '',\n    followUpDate: body.followUpDate || null\n  }\n}];"
      },
