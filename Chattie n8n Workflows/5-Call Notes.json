    {
      "parameters": {
        "jsCode": "// Merge contact data with payload\nconst raw = $input.first().json;\nconst rows = Array.isArray(raw) ? raw : (Array.isArray(raw.body) ? raw.body : [raw]);\nconst contact = rows[0] || {};\nconst payload = $node['Extract Payload'].json;\n\nreturn [{\n  json: {\n    contactId: payload.contactId,\n    conversationId: payload.conversationId,\n    notes: payload.notes,\n    outcome: payload.outcome,\n    followUpDate: payload.followUpDate,\n    contactName: contact.name || 'Onbekend',\n    contactPhone: contact.phone || ''\n  }\n}];"
      },
      "id": "f8e02270-519b-4671-8bb1-d12a0ae3297e",
      "name": "Merge Contact + Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        0
      ]
    },
    {
