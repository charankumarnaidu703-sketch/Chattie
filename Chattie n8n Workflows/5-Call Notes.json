        "method": "POST",
        "url": "=https://rifktjxmadzfrdclxpfz.supabase.co/rest/v1/call_notes",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contact_id: $json.contactId, conversation_id: $json.conversationId, notes: $json.notes, outcome: $json.outcome, follow_up_date: $json.followUpDate, gmail_sent: false, created_at: new Date().toISOString() }) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "7347a7cd-57a8-4eba-bcd2-7e671e711769",
      "name": "Save Call Note to Supabase",
      "type": "n8n-nodes-base.httpRequest",
