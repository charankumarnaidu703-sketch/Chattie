    {
      "parameters": {
        "jsCode": "// Build Call Note Email HTML\nconst data = $node['Merge Contact + Payload'].json;\nconst callNote = $input.first().json;\nconst callNoteRow = Array.isArray(callNote) ? callNote[0] : (Array.isArray(callNote.body) ? callNote.body[0] : callNote);\n\nconst callNoteId = callNoteRow.id || '';\nconst followUpStr = data.followUpDate \n  ? new Date(data.followUpDate).toLocaleDateString('nl-NL', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })\n  : 'Geen vervolgdatum gepland';\n\nconst outcomeEmoji = {\n  'interested': '✅',\n  'not_interested': '❌',\n  'callback': '📞',\n  'voicemail': '📭',\n  'no_answer': '📵'\n};\nconst emoji = outcomeEmoji[data.outcome] || '📝';\n\nconst html = `<!DOCTYPE html>\n<html>\n<body style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <div style=\"background: #3b82f6; padding: 20px; border-radius: 8px 8px 0 0;\">\n    <h1 style=\"color: white; margin: 0; font-size: 20px;\">${emoji} Belnotitie: ${data.contactName}</h1>\n    <p style=\"color: #dbeafe; margin: 8px 0 0 0;\">${new Date().toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</p>\n  </div>\n  \n  <div style=\"background: #eff6ff; padding: 20px; border: 1px solid #93c5fd; border-top: none;\">\n    <table style=\"width: 100%; border-collapse: collapse;\">\n      <tr><td style=\"padding: 8px; font-weight: bold; width: 130px;\">Naam:</td>\n          <td style=\"padding: 8px;\">${data.contactName}</td></tr>\n      <tr style=\"background: white;\"><td style=\"padding: 8px; font-weight: bold;\">Telefoon:</td>\n          <td style=\"padding: 8px;\">${data.contactPhone}</td></tr>\n      <tr><td style=\"padding: 8px; font-weight: bold;\">Uitkomst:</td>\n          <td style=\"padding: 8px;\"><strong>${data.outcome}</strong></td></tr>\n      <tr style=\"background: white;\"><td style=\"padding: 8px; font-weight: bold;\">Vervolg:</td>\n          <td style=\"padding: 8px;\">${followUpStr}</td></tr>\n    </table>\n    \n    <h3 style=\"color: #1d4ed8; margin-top: 20px;\">Notities</h3>\n    <div style=\"background: white; padding: 15px; border-radius: 6px; border: 1px solid #bfdbfe; white-space: pre-wrap;\">${data.notes}</div>\n  </div>\n  \n  <div style=\"background: #f8fafc; padding: 12px 20px; border: 1px solid #e2e8f0; border-top: none; border-radius: 0 0 8px 8px;\">\n    <p style=\"color: #94a3b8; font-size: 12px; margin: 0;\">Automatisch gegenereerd door Chattie</p>\n  </div>\n</body>\n</html>`;\n\nreturn [{\n  json: {\n    html: html,\n    contactName: data.contactName,\n    outcome: data.outcome,\n    callNoteId: callNoteId\n  }\n}];"
      },
